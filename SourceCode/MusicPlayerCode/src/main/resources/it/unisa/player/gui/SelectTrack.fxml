<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.player.gui.SelectTrackController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Aggiungi Brano" />
    
    <TableView fx:id="globalTracksTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" prefWidth="200.0" text="Titolo" />
            <TableColumn fx:id="authorColumn" prefWidth="190.0" text="Autore" />
        </columns>
    </TableView>

    <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-size: 13px;" visible="false" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button onAction="#onCancelClick" style="-fx-background-color: #a1a1a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 100;" text="Annulla" />
        <Button onAction="#onAddClick" style="-fx-background-color: #1c1c1e; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 100;" text="Aggiungi" />
    </HBox>
</VBox>