<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.player.gui.PlaylistController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER" spacing="10.0">
        <Button onAction="#onBackToLibraryClick" style="-fx-background-color: #a1a1a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-pref-height: 40; -fx-background-radius: 5;" text="Tracks" />
        <Button style="-fx-background-color: #1c1c1e; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-pref-height: 40; -fx-background-radius: 5;" text="Playlist" />
    </HBox>

    <TextField promptText="🔍 Ricerca Playlist" style="-fx-background-radius: 20; -fx-pref-height: 35;" />

    <TableView fx:id="playlistTable" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" prefWidth="209.60003662109375" text="Nome Playlist" />
            <TableColumn fx:id="deleteColumn" prefWidth="73.5999755859375" resizable="false" style="-fx-alignment: CENTER-RIGHT; -fx-padding: 0 10 0 0;" text="" />
            <TableColumn fx:id="editColumn" prefWidth="113.60003662109375" />
        </columns>
    </TableView>

    <HBox alignment="CENTER" translateY="-10">
        <Button onAction="#onUndoClick" style="-fx-background-color: #a1a1a6; -fx-text-fill: white; -fx-background-radius: 20; -fx-pref-width: 70;" text="Undo">
         <HBox.margin>
            <Insets right="240.0" />
         </HBox.margin></Button>
        <Button onAction="#onAddPlaylistClick" style="-fx-background-color: #a1a1a6; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40;" text="+" />
    </HBox>


</VBox>
